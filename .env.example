# ── Server ──────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ──────────────────────────
MONGODB_URI=mongodb://localhost:27017/momentum
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/momentum

# ── JWT ──────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── Email (Nodemailer) ───────────────
# Gmail example — use an App Password (not your real password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="Momentum Habits <your_gmail@gmail.com>"

# ── Frontend URL (for CORS) ──────────
CLIENT_URL=http://localhost:3000
